{
  "name": "@synmux/claude-commit",
  "version": "0.1.1",
  "description": "Generate git commit messages with Claude, using your Claude Code subscription.",
  "main": "index.ts",
  "module": "index.ts",
  "type": "module",
  "private": false,
  "bin": {
    "cco": "bin/cco.ts",
    "claude-commit": "bin/cco.ts"
  },
  "files": [
    "bin",
    "src",
    "index.ts"
  ],
  "claude-commit": {
    "conventionalCommits": true,
    "gitmoji": true,
    "multiline": true,
    "template": null,
    "customPrompt": null,
    "interactive": false,
    "interactiveCount": 3,
    "interactiveTemperature": 1,
    "models": {
      "summary": "sonnet[1m]",
      "final": "haiku"
    },
    "maxChunkTokens": 600000,
    "charsPerToken": 3.5,
    "allowApiKey": false
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.201",
    "@trunkio/launcher": "^1.3.4",
    "@types/bun": "^1.3.14",
    "prettier": "3.9.4",
    "skilld": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@opentui/core": "^0.4.3",
    "commander": "^15.0.0"
  },
  "scripts": {
    "start": "bun run bin/cco.ts",
    "test": "bun test",
    "format": "bun run prettier --write . && bun run trunk fmt -a",
    "lint": "bun run trunk check -a",
    "lint:fix": "bun run trunk check -a --fix",
    "typecheck": "bun run tsc --noEmit",
    "prepare": "bun run skilld prepare || true"
  }
}
