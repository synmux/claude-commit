{
  "name": "claudecommit",
  "version": "0.1.0",
  "description": "Generate git commit messages with Claude, using your Claude Code subscription.",
  "main": "index.ts",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "cc": "bin/cc.ts",
    "claudecommit": "bin/cc.ts"
  },
  "files": [
    "bin",
    "src",
    "index.ts"
  ],
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.197",
    "@trunkio/launcher": "^1.3.4",
    "@types/bun": "^1.3.14",
    "skilld": "^2.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.197",
    "@opentui/core": "^0.4.2",
    "commander": "^15.0.0"
  },
  "scripts": {
    "start": "bun run bin/cc.ts",
    "test": "bun test",
    "format": "bun run prettier --write . && bun run trunk fmt -a",
    "lint": "bun run trunk check -a",
    "lint:fix": "bun run trunk check -a --fix",
    "typecheck": "bun run tsc --noEmit",
    "prepare": "bun run skilld prepare || true"
  }
}
